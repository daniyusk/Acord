{
  "identifier": "remote-discord-main",
  "description": "Minimum permissions required by Acord's injected code on supported Discord origins",
  "local": false,
  "remote": {
    "urls": [
      "https://discord.com/*",
      "https://canary.discord.com/*",
      "https://ptb.discord.com/*"
    ]
  },
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "opener:allow-open-url",
    "opener:allow-default-urls",
    "allow-app-version",
    "allow-default-config",
    "allow-fetch-image",
    "allow-frontend-ready",
    "allow-get-enabled-themes",
    "allow-get-extra-css",
    "allow-get-index",
    "allow-get-injection-js",
    "allow-get-os-accent",
    "allow-get-platform",
    "allow-get-themes",
    "allow-load-mods-css",
    "allow-load-plugins",
    "allow-localize-imports",
    "allow-open-themes",
    "allow-read-config-file",
    "allow-restart-in-safemode",
    "allow-set-decorations",
    "allow-trigger-keys-pressed",
    "allow-write-config-file"
  ]
}
