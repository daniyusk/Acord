{
  "identifier": "default",
  "description": "Default permissions",
  "local": true,
  "remote": {
    "urls": [
      "https://discord.com/*",
      "https://*.discord.com/*"
    ]
  },
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:app:allow-version",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://**/*"
        },
        {
          "url": "http://**/*"
        }
      ]
    }
  ]
}
